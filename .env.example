# Copy to .env and fill in. Never commit .env.

# --- LLM (Gemini via LiteLLM) ---
GEMINI_API_KEY=
AGENT_MODEL=gemini/gemini-2.5-flash

# --- Database (Neon Postgres) ---
# Same database, two drivers. Sync (psycopg) for Lead CRUD; async (asyncpg) for chat memory.
# Sync needs SSL via the URL query string (?sslmode=require).
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Async SSL is set in code (connect_args ssl=True); do not add sslmode here.
ASYNC_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME

# --- Auth / sessions ---
ADMIN_TOKEN=
SESSION_SECRET=

# --- CORS (comma-separated; defaults to http://localhost:3000) ---
ALLOWED_ORIGINS=http://localhost:3000

# --- Rate limiting ---
CHAT_RATE_LIMIT=20/minute

# --- Bot protection & spend cap (F15) ---
# Cloudflare Turnstile secret key (server-side). Blank = bot check disabled (dev no-op);
# /session then mints without verifying. The matching public site key is the frontend's
# NEXT_PUBLIC_TURNSTILE_SITE_KEY.
TURNSTILE_SECRET_KEY=
# Max LLM-backed chat requests per UTC day, a global ceiling on spend. Blank = no cap;
# N caps the day at N requests; 0 blocks everything.
DAILY_LLM_CALL_CAP=

# --- SMTP (email notifications; leave blank to disable) ---
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=
