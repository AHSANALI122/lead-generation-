# Copy to .env and fill in. Never commit .env.

# --- LLM (Gemini via LiteLLM) ---
GEMINI_API_KEY=
AGENT_MODEL=gemini/gemini-2.5-flash

# --- Database (Neon Postgres) ---
# Same database, two drivers. Sync (psycopg) for Lead CRUD; async (asyncpg) for chat memory.
# Sync needs SSL via the URL query string (?sslmode=require).
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Async SSL is set in code (connect_args ssl=True); do not add sslmode here.
ASYNC_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME

# --- Auth / sessions ---
ADMIN_TOKEN=
SESSION_SECRET=

# --- CORS (comma-separated; defaults to http://localhost:3000) ---
ALLOWED_ORIGINS=http://localhost:3000

# --- Rate limiting ---
CHAT_RATE_LIMIT=20/minute

# --- Bot protection & spend cap (F15) ---
# Cloudflare Turnstile secret key (server-side). Blank = bot check disabled (dev no-op);
# /session then mints without verifying. The matching public site key is the frontend's
# NEXT_PUBLIC_TURNSTILE_SITE_KEY.
TURNSTILE_SECRET_KEY=
# Max LLM-backed chat requests per UTC day, a global ceiling on spend. Blank = no cap;
# N caps the day at N requests; 0 blocks everything.
DAILY_LLM_CALL_CAP=

# --- Product knowledge (RAG, F17) ---
# Gemini embedding model (via LiteLLM) used to embed the FAQ corpus + queries. Reuses
# GEMINI_API_KEY above; no separate key needed.
EMBED_MODEL=gemini/gemini-embedding-001
# Max corpus chunks returned per lookup.
KNOWLEDGE_TOP_K=3
# Cosine threshold a chunk must clear to count as relevant (0–1). Raise to be stricter
# (fewer, surer hits); lower to retrieve more. Below this the agent falls back.
KNOWLEDGE_MIN_SCORE=0.55

# --- SMTP (email notifications; leave blank to disable) ---
# Example below is for Gmail. SMTP_PASSWORD must be a 16-char Gmail App Password
# (Google Account > Security > 2-Step Verification > App passwords), NOT your normal
# password. Paste it without spaces. Port 465 = implicit SSL (what notify.py uses).
# SMTP_USER is the sending account; NOTIFY_EMAIL_TO is the team inbox that receives the
# alert (may be the same address). NOTIFY_EMAIL_FROM defaults to SMTP_USER if blank.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your16charAppPassword
NOTIFY_EMAIL_TO=team@gmail.com
NOTIFY_EMAIL_FROM=you@gmail.com
