# Copy to .env.local and adjust for your environment.

# Browser-visible base URL of the FastAPI backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ADMIN_TOKEN (server-only, no NEXT_PUBLIC_ prefix) is added in F13 for the
# /admin server component — the admin dashboard. Not needed for the chat widget.

# Cloudflare Turnstile site key for the widget's bot check (F15). Public by design
# (it's a site key, not a secret). Leave blank to disable the bot check in dev — the
# widget then mints sessions without a token and the backend skips verification.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
